{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve portfolio",
      "type": "shell",
      "command": "python3 -m http.server 3000",
      "options": {
        "cwd": "${workspaceFolder}/project"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP on",
          "endsPattern": "^$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
